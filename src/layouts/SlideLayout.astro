---
import '@fontsource-variable/inter';
import '@fontsource-variable/lora';
import ProgressBar from '../components/ProgressBar.astro';
import ThemeInit from '../components/ThemeInit.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ThemeInit />
  </head>
  <body>
    <ProgressBar
      id="progress"
      color="var(--progress)"
      transition="transform 0.4s cubic-bezier(0.16, 1, 0.3, 1)"
    />

    <div id="deck">
      <slot />
    </div>

    <a href="/" class="home-link" aria-label="Home">
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
        <polyline points="9 22 9 12 15 12 15 22"></polyline>
      </svg>
    </a>
    <button class="theme-toggle" type="button" id="theme-toggle" aria-label="Toggle theme">
    </button>
    <div id="counter"></div>
    <div id="hint">
      <span>Use</span>
      <kbd>&larr;</kbd>
      <kbd>&rarr;</kbd>
      <span>to navigate</span>
    </div>
  </body>
</html>

<style is:global>
  /* ═══════════════════════════════════════
     TOKENS
     ═══════════════════════════════════════ */
  :root {
    --bg: #ffffff;
    --text: #242424;
    --text-muted: #696969;
    --text-faint: #909090;
    --heading: #000000;
    --accent: #087da1;
    --progress: #bf7a00;
    --c-fundamentals: #087da1;
    --c-planning: #9a7200;
    --c-execution: #4a6fa5;
    --c-review: #b35c00;
    --c-verification: #1a7a3a;
    --c-meta: #6b4fa8;
    --border: #e0e0e0;
    --code-bg: #f5f5f5;
    --vignette: rgba(0, 0, 0, 0.04);
    --font-ui: 'Inter Variable', -apple-system, system-ui, sans-serif;
    --font-body: 'Lora Variable', Charter, Georgia, serif;
  }

  [data-theme='dark'] {
    --bg: #1c1c22;
    --text: #d0d0d4;
    --text-muted: #a0a0a6;
    --text-faint: #707078;
    --heading: #e2e2e6;
    --accent: #7cc4db;
    --progress: #e8a020;
    --c-fundamentals: #7cc4db;
    --c-planning: #d4a633;
    --c-execution: #7ea8d6;
    --c-review: #e09a55;
    --c-verification: #6dce8a;
    --c-meta: #b090e0;
    --border: #35353f;
    --code-bg: #2a2a31;
    --vignette: rgba(0, 0, 0, 0.15);
  }

  /* ═══════════════════════════════════════
     BASE
     ═══════════════════════════════════════ */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html,
  body {
    height: 100%;
    overflow: hidden;
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-ui);
    -webkit-font-smoothing: antialiased;
    transition:
      background 0.3s ease,
      color 0.3s ease;
  }

  [data-theme='dark'] body {
    -webkit-font-smoothing: auto;
  }

  /* Vignette */
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 50%, var(--vignette) 100%);
    pointer-events: none;
    z-index: 100;
  }

  /* ═══════════════════════════════════════
     SLIDE LAYOUT
     ═══════════════════════════════════════ */
  ::selection {
    background: color-mix(in srgb, var(--accent) 25%, transparent);
    color: var(--heading);
  }

  #deck {
    position: relative;
    width: 100%;
    height: 100%;
    user-select: none;
    cursor: default;
  }

  .slide {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 64px;
    opacity: 0;
    pointer-events: none;
  }

  .slide.active {
    opacity: 1;
    pointer-events: auto;
    transition: opacity 0.4s ease;
  }

  .slide__inner {
    max-width: 820px;
    width: 100%;
  }

  .slide--center .slide__inner {
    text-align: center;
  }

  /* ═══════════════════════════════════════
     REVEAL ANIMATION
     ═══════════════════════════════════════ */
  [data-reveal] {
    opacity: 0;
    transform: translateY(28px);
  }

  .slide.active [data-reveal] {
    opacity: 1;
    transform: translateY(0);
    transition:
      transform 0.8s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.6s ease;
    transition-delay: calc(var(--d, 0) * 100ms + 250ms);
  }

  @media (prefers-reduced-motion: reduce) {
    .slide,
    [data-reveal] {
      transition: none !important;
    }
    [data-reveal] {
      opacity: 1;
      transform: none;
    }
  }

  /* ═══════════════════════════════════════
     MOBILE
     ═══════════════════════════════════════ */
  @media (max-width: 640px) {
    .slide {
      padding: 32px 24px;
      overflow-y: auto;
    }

    .slide__inner {
      margin-top: auto;
      margin-bottom: auto;
    }
  }
</style>

<style>
  /* ═══════════════════════════════════════
     HOME LINK
     ═══════════════════════════════════════ */
  .home-link {
    position: fixed;
    top: 32px;
    left: 32px;
    color: var(--text-faint);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px;
    transition: color 0.15s ease;
    text-decoration: none;
    z-index: 200;
  }

  .home-link:hover {
    color: var(--text);
  }

  .home-link:visited {
    color: var(--text-faint);
  }

  .home-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* ═══════════════════════════════════════
     THEME TOGGLE
     ═══════════════════════════════════════ */
  .theme-toggle {
    all: unset;
    position: fixed;
    top: 32px;
    right: 32px;
    cursor: pointer;
    color: var(--text-faint);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8px;
    transition: color 0.15s ease;
    user-select: none;
    z-index: 200;
  }

  .theme-toggle:hover {
    color: var(--text);
  }

  .theme-toggle:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* ═══════════════════════════════════════
     COUNTER
     ═══════════════════════════════════════ */
  #counter {
    position: fixed;
    bottom: 24px;
    right: 32px;
    font-family: var(--font-ui);
    font-size: 13px;
    font-variant-numeric: tabular-nums lining-nums;
    color: var(--text-faint);
    z-index: 200;
    user-select: none;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  #counter.visible {
    opacity: 1;
  }

  /* ═══════════════════════════════════════
     HINT
     ═══════════════════════════════════════ */
  #hint {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-ui);
    font-size: 13px;
    color: var(--text-faint);
    z-index: 200;
    user-select: none;
    display: flex;
    align-items: center;
    gap: 6px;
    opacity: 0;
    animation: hint-in 0.6s ease 1.2s forwards;
    transition: opacity 0.4s ease;
  }

  #hint.hidden {
    opacity: 0 !important;
    animation: none;
  }

  #hint kbd {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: 12px;
    line-height: 1;
    padding: 3px 7px;
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text-muted);
  }

  @keyframes hint-in {
    from {
      opacity: 0;
      transform: translateX(-50%) translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }
  }

  @media (max-width: 640px) {
    #hint {
      display: none;
    }
  }
</style>

<script>
  import { updateThemeButton, toggleTheme } from '../utils/theme';

  const slides = document.querySelectorAll<HTMLElement>('.slide');
  const progress = document.getElementById('progress')!;
  const counter = document.getElementById('counter')!;
  const hint = document.getElementById('hint')!;
  const total = slides.length;
  let current = 0;
  let hasInteracted = false;

  function init() {
    const hash = parseInt(location.hash.replace('#', ''));
    if (hash > 0 && hash <= total) {
      current = hash - 1;
    }
    show(current);
  }

  function show(index: number) {
    if (index < 0 || index >= total) return;
    current = index;

    slides.forEach((s, i) => {
      if (i === current) {
        s.classList.add('active');
      } else {
        s.classList.remove('active');
      }
    });

    // Progress
    const pct = total > 1 ? (current / (total - 1)) * 100 : 0;
    progress.style.transform = `scaleX(${pct / 100})`;

    // Counter
    counter.textContent = `${current + 1}\u2009/\u2009${total}`;
    if (current > 0) {
      counter.classList.add('visible');
    } else {
      counter.classList.remove('visible');
    }

    // URL
    history.replaceState(null, '', current === 0 ? location.pathname : `#${current + 1}`);
  }

  function next() {
    if (current < total - 1) show(current + 1);
  }

  function prev() {
    if (current > 0) show(current - 1);
  }

  function dismissHint() {
    if (!hasInteracted) {
      hasInteracted = true;
      hint.classList.add('hidden');
    }
  }

  // Keyboard
  document.addEventListener('keydown', (e) => {
    dismissHint();
    switch (e.key) {
      case 'ArrowRight':
      case 'ArrowDown':
      case ' ':
        e.preventDefault();
        next();
        break;
      case 'ArrowLeft':
      case 'ArrowUp':
      case 'Backspace':
        e.preventDefault();
        prev();
        break;
      case 'Home':
        e.preventDefault();
        show(0);
        break;
      case 'End':
        e.preventDefault();
        show(total - 1);
        break;
      case 'f':
      case 'F':
        if (!e.metaKey && !e.ctrlKey) {
          e.preventDefault();
          const el = document.documentElement as any;
          const doc = document as any;
          if (doc.fullscreenElement || doc.webkitFullscreenElement) {
            (doc.exitFullscreen || doc.webkitExitFullscreen).call(doc);
          } else {
            (el.requestFullscreen || el.webkitRequestFullscreen).call(el);
          }
        }
        break;
    }
  });

  // Click to advance (but not on links)
  document.getElementById('deck')!.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.tagName === 'A' || target.closest('a')) return;
    dismissHint();
    next();
  });

  // Touch / swipe
  let touchStartX = 0;
  let touchStartY = 0;

  document.addEventListener(
    'touchstart',
    (e) => {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
    },
    { passive: true }
  );

  document.addEventListener(
    'touchend',
    (e) => {
      const dx = e.changedTouches[0].clientX - touchStartX;
      const dy = e.changedTouches[0].clientY - touchStartY;
      if (Math.abs(dx) < 40 || Math.abs(dy) > Math.abs(dx)) return;
      dismissHint();
      if (dx < 0) next();
      else prev();
    },
    { passive: true }
  );

  // Theme toggle
  const themeBtn = document.getElementById('theme-toggle')!;
  updateThemeButton(themeBtn);

  themeBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    toggleTheme();
    updateThemeButton(themeBtn);
  });

  init();
</script>
