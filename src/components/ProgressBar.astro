---
interface Props {
  id?: string;
  color?: string;
  transition?: string;
}

const { id = 'progress-bar', color = 'var(--progress)', transition } = Astro.props;
---

<div
  id={id}
  aria-hidden="true"
  style={`--bar-color: ${color};${transition ? ` --bar-transition: ${transition};` : ''}`}
>
</div>

<style>
  div {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: var(--bar-color);
    z-index: 1000;
    transform-origin: left;
    transform: scaleX(0);
    transition: var(--bar-transition, none);
    will-change: transform;
  }
</style>
